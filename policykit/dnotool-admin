#!/bin/bash
# DNOTool Admin Wrapper Script
# Запуск от root, но с конфигами пользователя

set -e

DNOTOOL_BIN="/usr/local/bin/dnotool"
# Сохраняем путь к домашней директории текущего пользователя
USER_HOME="$HOME"

if ! command -v pkexec &> /dev/null; then
    echo "Error: pkexec is not installed." >&2
    exit 1
fi

# pkexec очищает HOME, поэтому мы передаем его принудительно через env
# Также передаем XDG_CONFIG_HOME, чтобы приложение искало конфиги в вашем .config
exec pkexec env DISPLAY="$DISPLAY" \
             XAUTHORITY="$XAUTHORITY" \
             XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" \
             HOME="$USER_HOME" \
             XDG_CONFIG_HOME="$USER_HOME/.config" \
             QT_QPA_PLATFORMTHEME="kde" \
             "$DNOTOOL_BIN" "$@"